[Unit]
Description=Telegram Account Viewer
After=network.target

[Service]
User=www-data
WorkingDirectory=/opt/tgviewer
EnvironmentFile=/opt/tgviewer/.env
ExecStart=/opt/tgviewer/venv/bin/gunicorn -w 1 --threads 4 -b 127.0.0.1:5000 --timeout 120 --access-logfile - app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
